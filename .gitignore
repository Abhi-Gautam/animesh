# Ignore build outputs
/target/

# Ignore Cargo lock file (optional)
Cargo.lock
.DS_Store

# Ignore backups and temporary files
*.rs.bk

# Test artifacts (SQLite files written by tests via ANIMESH_DB_PATH)
*.db
*.db-wal
*.db-shm

# Insta snapshot pending files (review before committing as .snap)
**/*.snap.new

# Local scratch / harvested sample data (source-lake outputs etc.)
/scratchpad/
